// ── Page frame: half-letter (5.5x8.5in) field guide, a uniform 1cm margin all round ──
\geometry paperwidth:5.5in paperheight:8.5in left:1cm right:1cm top:1cm bottom:1cm

// The Arabic / English edition of the field reference. Same facing-pair design as the other
// editions, mirrored for a right-to-left language: the Arabic take of each card sits on the left
// (verso) page and the matching English take on the right (recto). The English cards are the same
// text as the other editions.

// Arabic is set in Noto Naskh Arabic (the bundled `arabic` face: regular + bold), laid out
// right-to-left with cursive joining and lam-alef ligatures by the engine's shaper. Following
// Arabic print convention, the running prose is set unvocalized and only the scripture is
// vocalized (harakat).

// Scripture: public-domain translations — the Arabic from the Smith–Van Dyck Bible (1865), the
// Berean Standard Bible in English.

// Rendered and verified on texish 0.13.1 (right-to-left shaping, harakat, the Allah ligature, and
// right-to-left lists). The Arabic prose is unverified and still needs a fluent-Arabic proofread; the
// scripture is sourced verbatim from the Van Dyck text.

\def footline {\hss}

// ════════════════════════════════════════════════════════════════════════════
// Card authoring vocabulary. The body face is parameterized (\bodyface) so the shared card macros
// set Arabic on the verso and Latin on the recto. The Arabic card head, labels, bullets and verses
// are paragraph-based (not \leftline) so the bidi reorderer turns each line into visual order; the
// Latin side keeps the \leftline heads of the other editions.
// ════════════════════════════════════════════════════════════════════════════
\newcounter{card}

\def topicar {}
\def topicen {}
\def settopic a e {\def topicar {\a}\def topicen {\e}}

\def bodyface {lmroman}
\def qfontsize {11}

// Arabic head: a right-to-left paragraph (rtl is active in the `ar` environment), flush right via
// \noindent. The number leads on the right, the tag follows; the section topic sits above.
\def cardheadarabic num topic tag {\noindent{\font arabic 10 regular \topic}

\noindent{\font arabic 16 bold \num\hskip 10 \tag}

\vskip 6pt
\noindent}

\def cardheadlatin num topic tag {
  \if {\> {\size{\topic}} {0}}\leftline{\font lmroman 9 regular \smallcaps{\topic}}\smallskip\fi
  \leftline{\font lmroman 15 bold \num\hskip 10 \tag}
  \vskip 6pt
  \noindent
}

\newenvironment ar tag {
  \rtl
  \def bodyface {arabic}
  \def qfontsize {11.5}
  \font arabic 10.5 regular
  \stepcounter{card}
  \addcontentsline{tocar}{1}{\arabic{\value{card}}}{\tag}
  \cardheadarabic{\arabic{\value{card}}}{\topicar}{\tag}
} {\ltr\vfil\eject}

\newenvironment en tag {
  \ltr
  \usehyphenation{en-us}
  \def bodyface {lmroman}
  \def qfontsize {11}
  \font lmroman 10 regular
  \addcontentsline{tocen}{1}{\arabic{\value{card}}}{\tag}
  \cardheadlatin{\arabic{\value{card}}}{\topicen}{\tag}
} {\vfil\eject}

// \q{…} — the objection itself: bold, flush to the leading edge, in the current body face.
\def q text {\noindent{\font \bodyface \qfontsize bold \text}

}

// Run-in labels: \lab (Latin, period lead-in) on the recto, \laba (Arabic, bold) on the verso.
\def lab t {\textbf{\t.}}
\def laba t {\textbf{\t}}


// \verse{ref}{text} — a printed scripture verse: a bold reference, then the verse set flush.
\def verse r body {\noindent\textbf{\r}\hskip 6 \body

\vskip 2pt}

\def tocleader {\leaders\hbox to:0.5em {\hss.\hss}{0pt plus 1fil}}
// Arabic TOC entry: a right-to-left paragraph so the title reorders; number on the right, page on
// the left, dotted leader between (justified to full width via \set parfillskip {0} in the group).
\def tocarformat lvl num ttl pg {\noindent\num\hskip 8 \ttl\tocleader\hskip 6 \pg

}
\def tocenformat lvl num ttl pg {\hbox to:\hsize {\num\hskip 8 \ttl\tocleader\hskip 6 \pg}}

