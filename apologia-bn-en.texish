// ════════════════════════════════════════════════════════════════════════════
// Card authoring vocabulary. The left-hand (Bengali) environment is \begin{bn} and sets the
// Bengali face; its run-in helpers (\qb \labb \verseb \cardheadbn) mirror the English ones
// but typeset in bengali. The right-hand English side keeps the lmroman helpers.
// ════════════════════════════════════════════════════════════════════════════
\newcounter{card}

\def topicbn {}
\def topicen {}
\def settopic b e {\def topicbn {\b}\def topicen {\e}}

// English card head (lmroman)
\def cardhead num topic tag {
  \if {\> {\size{\topic}} {0}}\leftline{\font lmroman 9 regular \smallcaps{\topic}}\smallskip\fi
  \leftline{\font lmroman 15 bold \num\hskip 10 \tag}
  \vskip 6pt
  \noindent
}

// Bengali card head (bengali — no small caps in Bengali)
\def cardheadbn num topic tag {
  \if {\> {\size{\topic}} {0}}\leftline{\font bengali 9 regular \topic}\smallskip\fi
  \leftline{\font bengali 14 bold \num\hskip 10 \tag}
  \vskip 6pt
  \noindent
}

\newenvironment bn tag {
  \font bengali 10 regular
  \stepcounter{card}
  \addcontentsline{tocbn}{1}{\arabic{\value{card}}}{\tag}
  \cardheadbn{\arabic{\value{card}}}{\topicbn}{\tag}
} {\vfil\eject}

\newenvironment en tag {
  \font lmroman 10 regular
  \usehyphenation{en-us}
  \addcontentsline{tocen}{1}{\arabic{\value{card}}}{\tag}
  \cardhead{\arabic{\value{card}}}{\topicen}{\tag}
} {\vfil\eject}

// English run-in helpers
\def q text {\noindent{\font lmroman 11 bold \text}\par}
\def lab t {\textbf{\t.}}
\def verse r body {\noindent\textbf{\r}\hskip 6 \body\par\smallskip}

// Bengali run-in helpers (bengali)
\def qb text {\noindent{\font bengali 11 bold \text}\par}
\def labb t {\textbf{\t}\hskip 5 }
\def verseb r body {\noindent\textbf{\r}\hskip 6 \body\par\smallskip}

\def tocleader {\leaders\hbox to:0.5em {\hss.\hss}{0pt plus 1fil}}
\def tocbnformat lvl num ttl pg {\hbox to:\hsize {\num\hskip 8 {\font bengali 10 regular \ttl}\tocleader\hskip 6 \pg}}
\def tocenformat lvl num ttl pg {\hbox to:\hsize {\num\hskip 8 \ttl\tocleader\hskip 6 \pg}}

