// The Hebrew / English edition of the field reference. Same facing-pair design as the other
// editions, mirrored for a right-to-left language: the Hebrew take of each card sits on the left
// (verso) page and the matching English take on the right (recto). The English cards are the same
// text as the other editions.

// Hebrew is set in Noto Serif Hebrew (the bundled `hebrew` face: regular + bold) and laid out
// right-to-left by the engine's bidirectional algorithm. Following Hebrew print convention, the
// running prose is set unpointed and only the scripture is vocalized (niqqud).

// Scripture: public-domain translations — the New Testament from the Salkinson-Ginsburg Hebrew
// New Testament (1885) and the Old Testament from the Westminster Leningrad Codex in Hebrew, the
// Berean Standard Bible in English.

\def footline {\hss}

// ════════════════════════════════════════════════════════════════════════════
// Card authoring vocabulary. The body face is parameterized (\bodyface) so the shared card
// macros set Hebrew on the verso and Latin on the recto. The Hebrew card head and bullets are
// paragraph-based (not \leftline) so the bidi reorderer turns each line into visual order; the
// Latin side keeps the \leftline heads of the other editions.
// ════════════════════════════════════════════════════════════════════════════
\newcounter{card}

\def topiche {}
\def topicen {}
\def settopic h e {\def topiche {\h}\def topicen {\e}}

\def bodyface {lmroman}
\def qfontsize {11}

// Hebrew head: a right-to-left paragraph (rtl is already active in the `he` environment). The
// number leads on the right, the tag follows; the section topic sits above in a smaller cut.
\def cardheadhebrew num topic tag {{\font hebrew 10 regular \topic}

{\font hebrew 16 bold \num\hskip 10 \tag}

\vskip 6pt
\noindent}

\def cardheadlatin num topic tag {
  \if {\> {\size{\topic}} {0}}\leftline{\font lmroman 9 regular \smallcaps{\topic}}\smallskip\fi
  \leftline{\font lmroman 15 bold \num\hskip 10 \tag}
  \vskip 6pt
  \noindent
}

\newenvironment he tag {
  \rtl
  \def bodyface {hebrew}
  \def qfontsize {12.5}
  \font hebrew 11.5 regular
  \stepcounter{card}
  \addcontentsline{toche}{1}{\arabic{\value{card}}}{\tag}
  \cardheadhebrew{\arabic{\value{card}}}{\topiche}{\tag}
} {\ltr\vfil\eject}

\newenvironment en tag {
  \ltr
  \usehyphenation{en-us}
  \def bodyface {lmroman}
  \def qfontsize {11}
  \font lmroman 10 regular
  \addcontentsline{tocen}{1}{\arabic{\value{card}}}{\tag}
  \cardheadlatin{\arabic{\value{card}}}{\topicen}{\tag}
} {\vfil\eject}

// \q{…} — the objection itself: bold, flush to the leading edge, in the current body face.
\def q text {\noindent{\font \bodyface \qfontsize bold \text}

}

// Run-in labels: \lab (Latin, period lead-in) on the recto, \labh (Hebrew, bold) on the verso.
\def lab t {\textbf{\t.}}
\def labh t {\textbf{\t}}

// \bull{…} — a Hebrew bullet item: a flush-right paragraph led by a bullet on the right.
\def bull text {\noindent •\hskip 4 \text

}

// \verse{ref}{text} — a printed scripture verse: a bold reference, then the verse set flush.
\def verse r body {\noindent\textbf{\r}\hskip 6 \body

\smallskip}

\def tocleader {\leaders\hbox to:0.5em {\hss.\hss}{0pt plus 1fil}}
// Hebrew TOC entry: a right-to-left paragraph so the title reorders; number on the right, page on
// the left, dotted leader between.
\def tocheformat lvl num ttl pg {\noindent\num\hskip 8 \ttl\tocleader\hskip 6 \pg

}
\def tocenformat lvl num ttl pg {\hbox to:\hsize {\num\hskip 8 \ttl\tocleader\hskip 6 \pg}}

