// Card authoring vocabulary. The left-hand (Hindi) environment is \begin{hi} and sets the
// Devanagari face; its run-in helpers (\qh \labh \verseh \cardheadhi) mirror the English ones
// but typeset in devanagari. The right-hand English side keeps the lmroman helpers.
// ════════════════════════════════════════════════════════════════════════════
\newcounter{card}

\def topichi {}
\def topicen {}
\def settopic h e {\def topichi {\h}\def topicen {\e}}

// English card head (lmroman)
\def cardhead num topic tag {
  \if {\> {\size{\topic}} {0}}\leftline{\font lmroman 9 regular \smallcaps{\topic}}\smallskip\fi
  \leftline{\font lmroman 15 bold \num\hskip 10 \tag}
  \vskip 6pt
  \noindent
}

// Hindi card head (devanagari — no small caps in Devanagari)
\def cardheadhi num topic tag {
  \if {\> {\size{\topic}} {0}}\leftline{\font devanagari 9 regular \topic}\smallskip\fi
  \leftline{\font devanagari 14 bold \num\hskip 10 \tag}
  \vskip 6pt
  \noindent
}

\newenvironment hi tag {
  \font devanagari 10 regular
  \stepcounter{card}
  \addcontentsline{tochi}{1}{\arabic{\value{card}}}{\tag}
  \cardheadhi{\arabic{\value{card}}}{\topichi}{\tag}
} {\vfil\eject}

\newenvironment en tag {
  \font lmroman 10 regular
  \usehyphenation{en-us}
  \addcontentsline{tocen}{1}{\arabic{\value{card}}}{\tag}
  \cardhead{\arabic{\value{card}}}{\topicen}{\tag}
} {\vfil\eject}

// English run-in helpers
\def q text {\noindent{\font lmroman 11 bold \text}

}
\def lab t {\textbf{\t.}}
\def verse r body {\noindent\textbf{\r}\hskip 6 \body

\smallskip}

// Hindi run-in helpers (devanagari)
\def qh text {\noindent{\font devanagari 11 bold \text}

}
\def labh t {\textbf{\t}\hskip 5 }
\def verseh r body {\noindent\textbf{\r}\hskip 6 \body

\smallskip}

\def tocleader {\leaders\hbox to:0.5em {\hss.\hss}{0pt plus 1fil}}
\def tochiformat lvl num ttl pg {\hbox to:\hsize {\num\hskip 8 {\font devanagari 10 regular \ttl}\tocleader\hskip 6 \pg}}
\def tocenformat lvl num ttl pg {\hbox to:\hsize {\num\hskip 8 \ttl\tocleader\hskip 6 \pg}}

